# ─────────────────────────────────────────────────────────────────────────────
# Reverb server (the daemon) — where it LISTENS
# ─────────────────────────────────────────────────────────────────────────────
# IP/host the Reverb process binds to. Use 0.0.0.0 to listen on all interfaces,
# or 127.0.0.1 to accept only local connections on this machine.
REVERB_SERVER_HOST=0.0.0.0

# TCP port the Reverb process listens on.
REVERB_SERVER_PORT=13000

# ─────────────────────────────────────────────────────────────────────────────
# Backend → Reverb (Laravel publisher endpoint)
# ─────────────────────────────────────────────────────────────────────────────
# The address your Laravel app uses to send events to Reverb.
# Use a hostname/IP that is reachable FROM THE LARAVEL APP.
# Examples:
#  - Same host (no proxy):      REVERB_HOST=127.0.0.1  REVERB_PORT=13000  REVERB_SCHEME=http
#  - Internal hostname (Docker): REVERB_HOST=reverb    REVERB_PORT=13000  REVERB_SCHEME=http
#  - Through HTTPS proxy (rare): REVERB_HOST=api.example.com REVERB_PORT=443 REVERB_SCHEME=https
REVERB_HOST=localhost
REVERB_PORT=13000
REVERB_SCHEME=http

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (browser) → WebSocket endpoint
# ─────────────────────────────────────────────────────────────────────────────
# The public host/port/scheme the BROWSER connects to via WebSocket.
# Often this is your web server / reverse proxy (e.g., Nginx), not the raw Reverb port.
# Examples:
#  - Through Nginx on HTTP:   VITE_REVERB_HOST=site.local   VITE_REVERB_PORT=80    VITE_REVERB_SCHEME=http
#  - Through Nginx on HTTPS:  VITE_REVERB_HOST=site.com     VITE_REVERB_PORT=443   VITE_REVERB_SCHEME=https
#  - Direct to Reverb (dev):  VITE_REVERB_HOST=127.0.0.1    VITE_REVERB_PORT=13000 VITE_REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="localhost"
VITE_REVERB_PORT="13000"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"


VITE_REVERB_CONNECTION_STATUS=off

VIDEO_PROCESS_LOGGING=false
AUDIO_PROCESS_LOGGING=false

GIPHY_API_KEY=DgjKC2iyZ1mRZ1iJfmuj8HNhrlSokj7y

VITE_GIPHY_API_KEY="${GIPHY_API_KEY}"
